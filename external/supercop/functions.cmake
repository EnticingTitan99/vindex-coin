# ---------------------------------------------------------------------------
# Wallet crypto backend detection
#
# vindex_crypto_autodetect(AVAILABLE <var> BEST <var>)
#
#   AVAILABLE - populated with a list of available backends
#   BEST      - set to the single best backend for this platform, or unset
#
# Backends (in preference order):
#   arm   - ARMv8-A with crypto extensions
#   aesni - x86/x86_64 with AES-NI + SSE4.1
#   cn    - portable CryptoNote internal (always available, used as fallback)
# ---------------------------------------------------------------------------

function(vindex_crypto_autodetect)
  cmake_parse_arguments(AUTODETECT "" "AVAILABLE;BEST" "" ${ARGN})

  set(_available "")
  set(_best "")

  # ---- ARM crypto extensions ----
  if(ARM8)
    check_cxx_compiler_flag("-march=${ARCH}+crypto" _arm_crypto_ok)
    if(_arm_crypto_ok)
      list(APPEND _available "arm")
      if(NOT _best)
        set(_best "arm")
      endif()
    endif()
  endif()

  # ---- x86/x86_64 AES-NI ----
  if(NOT ARM AND NOT PPC64LE AND NOT PPC64 AND NOT PPC AND NOT S390X AND NOT RISCV AND NOT LOONGARCH)
    include(CheckCXXSourceCompiles)
    set(_aesni_test_src "
#include <wmmintrin.h>
#include <emmintrin.h>
#include <smmintrin.h>
int main() {
    __m128i a = _mm_setzero_si128();
    __m128i b = _mm_aesenc_si128(a, a);
    (void)b;
    return 0;
}
")
    set(CMAKE_REQUIRED_FLAGS "-maes -msse4.1")
    check_cxx_source_compiles("${_aesni_test_src}" _aesni_ok)
    unset(CMAKE_REQUIRED_FLAGS)

    if(_aesni_ok)
      list(APPEND _available "aesni")
      if(NOT _best)
        set(_best "aesni")
      endif()
    endif()
  endif()

  # ---- cn (portable, always available) ----
  list(APPEND _available "cn")
  if(NOT _best)
    set(_best "cn")
  endif()

  # Return results to the caller's scope
  if(AUTODETECT_AVAILABLE)
    set(${AUTODETECT_AVAILABLE} "${_available}" PARENT_SCOPE)
  endif()
  if(AUTODETECT_BEST)
    set(${AUTODETECT_BEST} "${_best}" PARENT_SCOPE)
  endif()
endfunction()

# ---------------------------------------------------------------------------
# vindex_crypto_get_target(<backend> <out_var>)
#   Maps a backend name to its CMake library target name.
# ---------------------------------------------------------------------------
function(vindex_crypto_get_target backend out_var)
  if(backend STREQUAL "aesni")
    set(${out_var} "aesni-crypto" PARENT_SCOPE)
  elseif(backend STREQUAL "arm")
    set(${out_var} "arm-crypto" PARENT_SCOPE)
  else()
    set(${out_var} "cncrypto" PARENT_SCOPE)
  endif()
endfunction()

# ---------------------------------------------------------------------------
# vindex_crypto_generate_header(<backend> <output_path>)
#   Writes the ops.h shim header for the selected backend.
# ---------------------------------------------------------------------------
function(vindex_crypto_generate_header backend output_path)
  if(backend STREQUAL "aesni")
    set(_impl "aesni")
  elseif(backend STREQUAL "arm")
    set(_impl "arm")
  else()
    set(_impl "cn")
  endif()

  file(WRITE "${output_path}"
"/* Auto-generated by external/supercop/functions.cmake - do not edit */
#pragma once
#include \"crypto/wallet/${_impl}/ops.h\"
")
endfunction()
